# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# --- Public (exposed to the browser; must be PUBLIC_-prefixed in SvelteKit) ---
# RPC endpoints. ENS resolution lives on mainnet; Sepolia is for testnet signing.
PUBLIC_RPC_URL_MAINNET=https://cloudflare-eth.com
PUBLIC_RPC_URL_SEPOLIA=https://rpc.sepolia.org

# --- Server-only secrets (NO PUBLIC_ prefix; keep out of client bundles) ---
# Etherscan API key — optional, for tx links / richer history in the UI.
ETHERSCAN_API_KEY=
# LLM API key (Gemini) — optional, for the agent reasoning "brain".
LLM_API_KEY=

# NEVER add a hot signing private key. Signing happens on the Ledger device.
